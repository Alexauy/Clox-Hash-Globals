// Test 1: Basic global variable assignment (exercises string keys)
var greeting = "Hello";
print greeting;  // Should print: Hello

// Test 2: Multiple string variables
var x = 10;
var y = 20;
print x + y;  // Should print: 30

// Test 3: Reassignment (updates existing key in hash table)
var counter = 5;
print counter;    // Should print: 5
counter = counter + 1;
print counter;    // Should print: 6

// Test 4: Boolean values (tests hashing and equality of booleans)
var isTrue = true;
var isFalse = false;
print isTrue;    // Should print: true
print isFalse;   // Should print: false

// Test 5: Nil value 
var nothing = nil;
print nothing;   // Should print: nil

// Test 6: Number values
var pi = 3.14159;
var answer = 42;
print pi;        // Should print: 3.14159
print answer;    // Should print: 42

// Test 7: Mixed variable types and operations
var str = "test";
var num = 100;
var bool = true;
var empty = nil;
print str;       // Should print: test
print num;       // Should print: 100
print bool;      // Should print: true
print empty;     // Should print: nil

// Test 8: Boolean operations (tests hash consistency with multiple booleans)
var test1 = true;
var test2 = true;
var test3 = false;
print test1;     // Should print: true
print test2;     // Should print: true
print test3;     // Should print: false

// Test 9: Nil reassignment
var val = nil;
val = 42;
print val;       // Should print: 42
val = nil;
print val;       // Should print: nil

// Test 10: Hash table collision handling
// These numbers might hash to similar values, testing collision resolution
var a = 1.0;
var b = 2.0;
var c = 3.0;
var d = 4.0;
var e = 5.0;
print a;         // Should print: 1
print b;         // Should print: 2
print c;         // Should print: 3
print d;         // Should print: 4
print e;         // Should print: 5

// Test 11: Verify all values persists correctly after many assignments
print greeting;  // Should still print: Hello
print x;         // Should still print: 10
print counter;   // Should print: 6
